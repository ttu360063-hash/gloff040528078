        usuario = $(this).attr('usuario');
        frase = $(this).attr('mensagem') ? $(this).attr('mensagem') : 'Volto já';
        $.ajax({
            type: "POST",
            dataType: "json",
            url: DIR+"!/tempo",
            data: "tempo="+tempo+"&usuario="+usuario+'&frase='+frase,
            success: function( data) {
                retornoAjax(data);
                if(data.success) {
