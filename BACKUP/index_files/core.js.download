        $('[modal-bonificar_pedido]').val('');
        $('[modal-bonificar_comentario]').val('');
    })
});

$.fn.serializeObject = function() {
    var o = {};
    var a = this.serializeArray();
    $.each(a, function() {
        if (o[this.name]) {
            if (!o[this.name].push) {
                o[this.name] = [o[this.name]];
            }
            o[this.name].push(this.value || '');
        } else {
            o[this.name] = this.value || '';
        }
    });
    return o;
};

$(document).on("change", '[name=timbre]', function(e, inndex, newValue, oldValue) {
    if($ID = $('#pedido_voz').val()) {
        $form = $('#formPedir').serializeObject();
        $estilo = $form.timbre ? $form.timbre : $form.estilo;
        $.ajax({
            type: "POST",
            dataType: "json",
            url: DIR+"!/disponibilidade",
            data: 'acao=consultar&locutor='+$ID+'&estilo='+$estilo,
            success: function( data ) {
                retornoAjax(data);
                viewInfoLocutor(data);
            },
            error: function( data ) {
                alert( 'Houve um erro imprevisto. Atualize a página.');
            }
        });
    }
});

$('#pedido_voz').on("change", function(e) {
    $ID = $(this).val();
    $nome = $(this).find('option:selected').text();
    updateNomeLocutor(this, $nome, $ID);
    $form = $('#formPedir').serializeObject();
    $estilo = $form.timbre ? $form.timbre : $form.estilo;
    $.ajax({
        type: "POST",
        dataType: "json",
        url: DIR+"!/disponibilidade",
        data: 'acao=consultar&locutor='+$ID+'&estilo='+$estilo,
        success: function( data ) {
            retornoAjax(data);
            viewInfoLocutor(data);
            if(data?.velocidades) {
                vl = data.velocidades;
            } else {
                vl = null;
            }
            $('textarea[name=texto]').trigger('change');
        },
        error: function( data ) {
            console.log('Error: '+data.responseText);
            alert( 'Houve um erro imprevisto. Atualize a página.');
        }
    });
    $('[btnVerHorario]').attr('ver-horario', $ID);
}); if($('#pedido_voz').val()) { $('#pedido_voz').trigger('change'); }

function updateNomeLocutor($this, $nome, $ID) {
    index = $($this).attr('data-tail-select').replace('tail-', '');
    select = $('.tail-select')[index]
    $(select).find('.select-label .label-inner').html($nome);
    $(select).find('.dropdown-option').removeClass('selected');
}

/*
$('body').on('DOMSubtreeModified', '.ck-editor__editable', function(){
    if($ta = $(this).closest('[conteudoEditor]').find('textarea')) {
        texto = $(this).html();
        $($ta).val(texto).trigger('change');
    }
})
*/
const targetNode = document.querySelector('.ck-editor__editable');
const config = { childList: true, subtree: true, characterData: true };
const callback = function(mutationsList, observer) {
    for (const mutation of mutationsList) {
        if (mutation.type === 'childList' || mutation.type === 'characterData') {
            const $ta = $(mutation.target).closest('[conteudoEditor]').find('textarea');
            if ($ta.length) {
                const texto = $(targetNode).html();
                $($ta).val(texto).trigger('change');
            }
        }
    }
};
const observer = new MutationObserver(callback);
if(targetNode) { observer.observe(targetNode, config); }

function viewInfoLocutor(data) {
    if (data.off) {
        $('[ultimoOffPlayer]').html('<audio class="w-full" preload="metadata" controls src="'+data.off+'"></audio>');
        $('[ultimoOff]').show();
    } else {
        $('[ultimoOffPlayer]').html('');
        $('[ultimoOff]').hide();
    }
    if (data.contrato) {
        $('[hide_contrato]').hide();
        $('[tempo_comerciais]').html(data.contrato.minutos)

        $('[tempo_institucionais]').html(data.contrato.minutos)
        $('[tempo_religiosos]').html(data.contrato.minutos)
        $('[tempo_politico]').html(data.contrato.minutos)
        $('[tempo_espera]').html(data.contrato.minutos)

        if (data.contrato.obs && data.contrato.status) {
            $('[contrato_obs]').show().html(data.contrato.obs);
        } else {
            $('[contrato_obs]').hide();
        }

        $('[contrato_institucionais='+data.contrato.institucionais+']').show();
        $('[contrato_religiosos='+data.contrato.religiosos+']').show();
        $('[contrato_politico='+data.contrato.politico+']').show();
        $('[contrato_espera='+data.contrato.espera+']').show();
        $('[contrato_locutor]').show();
    } else {
        $('[contrato_locutor]').hide();
    }
}

$(document).on('keydown', '[estilo]', function(){
    $ID = $('#pedido_voz').val();
    $estilo = $(this).val();
    $.ajax({
        type: "POST",
        dataType: "json",
        url: DIR+"!/disponibilidade",
        data: 'acao=consultar&locutor='+$ID+'&estilo='+$estilo,
        success: function( data ) {
            if (data.off) {
                $('[ultimoOffPlayer]').html('<audio class="w-full" preload="metadata" controls src="'+data.off+'"></audio>');
                $('[ultimoOff]').show();
            } else {
                $('[ultimoOffPlayer]').html('');
                $('[ultimoOff]').hide();
            }
        },
        error: function( data ) {
            console.log('Error: '+data.responseText);
            alert( 'Houve um erro imprevisto. Atualize a página.');
        }
    });
});

function triggerChangeLocutor($ID) {
    $.ajax({
        type: "POST",
        dataType: "json",
        url: DIR+"!/disponibilidade",
        data: 'acao=consultar&locutor='+$ID,
        success: function( data ) {
            retornoAjax(data);
            if (data.contrato) {
                $('[hide_contrato]').hide();
                $('[tempo_comerciais]').html(data.contrato.minutos)

                $('[tempo_institucionais]').html(data.contrato.minutos)
                $('[tempo_religiosos]').html(data.contrato.minutos)
                $('[tempo_espera]').html(data.contrato.minutos)

                $('[contrato_religiosos='+data.contrato.religiosos+']').show();
                $('[contrato_espera='+data.contrato.espera+']').show();
                $('[contrato_institucionais='+data.contrato.institucionais+']').show();
                $('[contrato_locutor]').show();
            } else {
                $('[contrato_locutor]').hide();
            }
        },
        error: function( data ) {
            console.log('Error: '+data.responseText);
            alert( 'Houve um erro imprevisto. Atualize a página.');
        }
    });
}

$(document).on('click', '[ver-horario]', function(e){
    btn = $(this);
    locutor = $(this).attr('ver-horario');
    $.ajax({
        type: "POST",
        dataType: "html",
        url: DIR+'!/disponibilidade',
        data: 'acao=consultar-horarios&locutor='+locutor,
        beforeSend: function() {
            loader(btn);
        },
        success: function( data ) {
            $('#modal-horarios [data-horarios]').html(data);
            $('#modal-horarios').modal('show');
            unload(btn);
        },
        error: function( data ) {
            unload(btn);
            ajaxErro();
        },
        completed: function () {
            unload(btn);
        },
    });
})


function retornoAjax(r, extra = false) {

    if (typeof r !== 'object') {
        console.log(r);
        ajaxErro();
        return;
    }

    // Reset
    if (r.reset) {
        /* FIX */
        $(r.reset).trigger("reset");
        if ( $('.dropzone').length > 0 ) {
            Dropzone.forElement(".dropzone").removeAllFiles(true);
        }
        if (controle = $("[controle]")) {
            controle.attr('value', 0);
        }
    }

    // Mensagens
    if(r.titulo || r.msg) {
        alerta(r.mtipo, r.titulo, r.msg);
    }

    // Seleciona Foco
    if (r.focus) {
        $(r.focus).select();
        //$.scrollTo(r.focus);
    }

    // Novo Formulario
    if (r.novo_formulario) {
        $("[formulario]").attr("value", r.novo_formulario);
    }

    // JavaScript
    if (r.js) {
        eval(r.js)
    }
    // JavaScript
    if (r.jQuery) {
        eval(r.jQuery)
    }

    // Clear
    if (r.clear) {
        $(r.clear).val('');
    }

    // Select
    if( r.select ) {
        $(r.select).select();
    }

    // Redirecionamento
    if (r.href) {
        if (r.href == 'reload') {
            setTimeout( function(){
                window.location.reload()
            }, 1500)
        } else {
            setTimeout( function(){
                window.location.href = r.href
            }, 1500)
        }
    }

    // Download
    if (r.download) {
        setTimeout( function(){
            var iframe = document.createElement('iframe');
            iframe.ID = r.download;
            iframe.style.display = 'none';
            document.body.appendChild(iframe);
            iframe.src = DIR+'!/download/?d='+ r.download;
            
            if(extra) {
                prontos = $('[prontos]');
                antigo = $('[prontos]').first().html();
                atual = parseInt(antigo-1);
                if(atual > 0) {
                    prontos.html(atual);
                } else {
                    prontos.remove();
                }
                extra.remove();
            }

        }, 1000);
    }

    // Toggle Modal
    if (r.modal) {
        if($(r.modal).hasClass('show')) {
            $(r.modal).modal('toggle');
        }
    }

    // Draw
    if(r.draw) {
        $(r.draw).each( function() {
            $tabela = $('#'+$(this).attr('id')).DataTable();
            pagina = $tabela.page();
            $tabela.page(pagina).draw('page');
        })
    }
}

function ajaxErro(e) {
    alerta('danger', 'Falha ao Executar', 'Atualize a página e tente novamente.');
    throw new Error(e);
    if(e) {
        console.group('Falha ao executar ajax');
        console.log()
        console.groupEnd('Falha ao executar ajax');
    }
}

/**/ // COOKIES
function cCookie(name,value,days) {
    if (days) {
        var date = new Date();
        date.setTime(date.getTime()+(days*24*60*60*1000));
        var expires = "; expires="+date.toGMTString();
    }
    else var expires = "";
    document.cookie = name+"="+value+expires+"; path=/";
}
// Deletar Cookie
function dCookie(name) {
    cCookie(name,"",-1);
}

function cCookieHs(name,value,hs) {
    if (hs) {
        var date = new Date();
        date.setTime(date.getTime()+(hs*60*60*1000));
        var expires = "; expires="+date.toGMTString();
    }
    else var expires = "";
    document.cookie = name+"="+value+expires+"; path=/";
}


var uploader;

//## UPLOAD
if($('.dropzone').length) {
    
    $('.dropzone').each(function(){
        var dropzone = $(this);
        var formulario = $("[formulario]");
        var controle = $("[controle]");
        var pedido = $("[pedido]");
        var submit = $(controle.attr('submit'));

        // MaxFiles
        if( $(this).attr('maxFiles') ) {
            _maxFiles = $(this).attr('maxFiles')
        } else {
            _maxFiles = 100;
        }

        // extFilter
        if ($(['extFilter']).length) {
            _extFilter = $(dropzone).attr('extFilter');
        } else {
            _extFilter = 'audio/*, image/*, video/*, application/pdf, .doc, .opus, .ogg, .wav, .wave, .docx, text/*, audio/*;capture=microphone;capture=camera';
        }

        // Cliente
        if ($(['cliente']).length) {
            _cliente = $("[cliente]").attr('cliente');
        } else {
            _cliente = false;
        }

        uploader = new Dropzone(this, { // Make the whole body a dropzone

          url: DIR+"!/upload", // Set the url
          parallelUploads: 1,
          maxFiles: _maxFiles,
          maxFilesize: 200, //mb
          acceptedFiles: _extFilter, //
          //previewTemplate: previewTemplate,
          autoQueue: true, // Make sure the files aren't queued until manually added
          //previewsContainer: "#previews", // Define the container to display the previews
          //clickable: ".fileinput-button" // Define the element that should be used as click trigger to select files.,

          thumbnailWidth: 50,
          thumbnailHeight: 50,
          thumbnailHeight: 50,

          addRemoveLinks: true,

          createImageThumbnails: false,

          //previewTemplate: '<li class="list-group-item"><span data-dz-name></span><span class="badge badge-success dz-success-mark">✔ Concluído</span><span class="badge badge-danger dz-error-message">✘ <span data-dz-errormessage></span></span><div class="progress m-t-5"><div class="progress-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" data-dz-uploadprogress><span class="sr-only">0%</span></div></div></li>',

          removedfile: function(file) {
            
            if (file.status == 'success') {
                r = JSON.parse(file.xhr.response);
                $.ajax({
                    type: 'POST',
                    url: DIR+'!/upload',
                    data: "tipo=deletar&arquivo="+r.ID,
                    dataType: 'html'
                });
                var v = parseInt(controle.val())-parseInt(1);
                controle.attr('value', v);

                if(funcao = dropzone.attr('fnCalc')) {
                    eval(funcao);
                }
            }

            var _ref;
            return (_ref = file.previewElement) != null ? _ref.parentNode.removeChild(file.previewElement) : void 0;
          },
          dictDefaultMessage: "Clique ou arraste até aqui seus arquivos.",
          dictFallbackMessage: "Seu navegador não suporta arrastar e soltar uploads de arquivos.",
          dictFallbackText: "Por favor, use o formulário abaixo para enviar seus arquivos como nos velhos tempos.",
          dictFileTooBig: "Arquivo muito grande ({{filesize}}mb). Máximo permitido: {{maxFilesize}}mb.",
          dictInvalidFileType: "Você não pode carregar este tipo de arquivo. {{fileType}}",
          dictResponseError: "Server responded with {{statusCode}} code.",
          dictCancelUpload: "Cancelar",
          dictCancelUploadConfirmation: "Tem certeza que deseja cancelar?",
          dictRemoveFile: "Excluir",
          dictRemoveFileConfirmation: 'Tem certeza que deseja excluir este arquivo carregado?',
          dictMaxFilesExceeded: "Você não pode carregar mais arquivos.",


        });
        /*
        "drop", "dragstart", "dragend", "dragenter", "dragover", "dragleave",
        "addedfile", "addedfiles", "removedfile", "thumbnail", "error", "errormultiple",
        "processing", "processingmultiple", "uploadprogress", "totaluploadprogress",
        "sending", "sendingmultiple", "success", "successmultiple", "canceled",
        "canceledmultiple", "complete", "completemultiple", "reset", "maxfilesexceeded",
        "maxfilesreached", "queuecomplete";
        */
        // Start UPLOADS:
        uploader.on('addedfile', function(file, xhr, formData){
            controle.attr('uploader', 0);
            controle.attr('checkout', 0);
            loader(file.previewElement);
        });

        // Envia Informações de Sessão e Usuário
        uploader.on('sending', function(file, xhr, formData){

            formData.append('formulario', dropzone.attr('formulario') ? dropzone.attr('formulario') : $("[formulario]").val());
            formData.append('pedido', dropzone.attr('pedido') ? dropzone.attr('pedido') : $("[controle]").attr('pedido'));
            formData.append('tipo', dropzone.attr('tipo') ? dropzone.attr('tipo') : $("[controle]").attr('tipo'));
            formData.append('cliente', dropzone.attr('cliente') ? dropzone.attr('cliente') : $("[controle]").attr('cliente'));

            controle.attr('uploader', 0);
            controle.attr('checkout', 0);
            
        });
        // Completar UPLOADS:
        uploader.on('queuecomplete', function(file, xhr, formData){
            
            controle.attr('uploader', 1);
            if ($(controle).attr('envio') == 1 || $(dropzone).attr('envio') == 1) {
                submit.submit();
            }
            conclusao = dropzone.attr('conclusao')
            if (typeof conclusao !== typeof undefined && conclusao !== false) {
                eval(dropzone.attr('conclusao'));
            }

            if(funcao = dropzone.attr('fnCalc')) {
                eval(funcao);
            }

        });
        // Success
        uploader.on("success", function(file, r) {
            var v = parseInt(controle.val())+parseInt(1);
            controle.attr('value', v);
            $(file.previewElement).waitMe('hide');
        });
    })
}

