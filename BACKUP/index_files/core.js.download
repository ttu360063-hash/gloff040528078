$(document).on('click', '[addFavorito]', function(e){
    btn = $(this);
    locutor = $(this).attr('addFavorito');
    $.ajax({
        type: "POST",
        dataType: "json",
        url: DIR+'!/favoritos',
        data: 'acao=adicionar&locutor='+locutor,
        beforeSend: function() {
            loader(btn);
        },
        success: function( data ) {
            retornoAjax(data);
            unload(btn);
            if(data.success) {
                $(btn)
                    .removeClass('text-gray-700 bg-gray-200 dark:bg-gray-600 dark:border-dark-5 dark:text-gray-800')
                    .addClass('bg-theme-31 text-theme-6')
                    .attr('title', 'Remover dos Favoritos')
                    .removeAttr('addFavorito')
                    .attr('delFavorito', locutor);
            }
        },
        error: function( data ) {
            unload(btn);
            ajaxErro(data);
        },
        completed: function () {
            unload(btn);
        },
    });
})
$(document).on('click', '[delFavorito]', function(e){
    btn = $(this);
    locutor = $(this).attr('delFavorito');
    $.ajax({
        type: "POST",
        dataType: "json",
        url: DIR+'!/favoritos',
        data: 'acao=remover&locutor='+locutor,
        beforeSend: function() {
        },
        success: function( data ) {
            retornoAjax(data);
            unload(btn);
            if(data.success) {
                $(btn)
                    .addClass('text-gray-700 bg-gray-200 dark:bg-gray-600 dark:border-dark-5 dark:text-gray-800')
                    .removeClass('bg-theme-31 text-theme-6')
                    .attr('title', 'Adicionar aos Favoritos')
                    .removeAttr('delFavorito')
                    .attr('addFavorito', locutor);
            }
        },
        error: function( data ) {
            ajaxErro(data);
        },
        completed: function () {
            unload(btn);
        },
    });
})


function updateTables() {
    $('[table-data]').each( function() {
        $tabela = $('#'+$(this).attr('id')).DataTable();
        pagina = $tabela.page();
        $tabela.page(pagina).draw('page');
    })
    setTimeout(function(){ updateTables(); }, 90000);
}
setTimeout(function(){ updateTables(); }, 90000);


