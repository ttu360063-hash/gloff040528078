function playDemo(target) {

    _velocidades = {
        1: "Rápida",
        2: "Normal",
        3: "Lenta",
        '1': "Rápida",
        '2': "Normal",
        '3': "Lenta"
    }

    demo = $(target).attr('playDemo');
    nome = $(target).attr('nome');
    estilos = $(target).attr('estilos');
    demos = $(target).data('demos');
    lista_demos = listarDemos(demos);

    $('[modal_demos="nome"]').html(nome);
    $('[modal_demos="estilos"]').html(estilos);
    $('[modal_demos="demo_principal"]').attr('src', demo);
    d_demo = demo.split('/').pop();
    $('[modal_demos="demo_principal_download"]').attr('href', PATH+HD+"/demos/"+d_demo).attr('download', nome+" - "+d_demo)


    $('[modal_demos="lista_padroes"]').html('');
    $('[modal_demos="lista_outros"]').html('');


    if(demos?.padroes) {
        $.each(demos.padroes, function(k, d) {
            $('[modal_demos="lista_padroes"]').append('<span class="text-center capitalize text-lg mb-2 ml-3">'+d.estilo+' <small>('+_velocidades[d.velocidade]+')</small></span><div class="flex flex-row justify-align-center w-100 gap-3"><audio class="w-auto w-full" preload="none" controls class="col-sm-12" src="//hd.paineldegravacao.com.br/demos/'+d.demo+'"></audio><a href="'+PATH+HD+"/demos/"+d.demo+'" download="'+nome+" - "+d.demo+'" downloadDireto class="col-auto intro-x rounded-full button button--lg text-white bg-theme-1" target="_blank"><i class="fa fa-download"></i></a></div>');
        })
        $('[modal_demos="padroes"]').show();
    } else {
        $('[modal_demos="padroes"]').hide();
    }
    if(demos?.outros) {
        $.each(demos.outros, function(k, d) {
            $('[modal_demos="lista_outros"]').append('<span class="text-center capitalize text-lg mb-2 ml-3">'+d.estilo+' <small>('+_velocidades[d.velocidade]+')</small></span><div class="flex flex-row justify-align-center w-100 gap-3"><audio class="w-auto w-full" preload="none" controls class="col-sm-12" src="//hd.paineldegravacao.com.br/demos/'+d.demo+'"></audio><a href="'+PATH+HD+"/demos/"+d.demo+'" download="'+nome+" - "+d.demo+'" downloadDireto class="col-auto intro-x rounded-full button button--lg text-white bg-theme-1" target="_blank"><i class="fa fa-download"></i></a></div>');
        })
        $('[modal_demos="outros"]').show();
    } else {
        $('[modal_demos="outros"]').hide();
    }

    $('#modal-demo-completo').modal('show');

    $('[modal_demos="demo_principal"]').trigger('play');
}


// Fix $(document).on('hidden.bs.modal',  '#modal-demo-completo', function (event) {
const attrObserver = new MutationObserver((mutations) => {
    mutations.forEach(mu => {
        if (mu.type == "attributes" && mu.attributeName == "class") {
            if(!$('#modal-demo-completo').hasClass('overflow-y-auto')) {
                $('[modal_demos="demo_principal"]').attr('src', '');
                $('[modal_demos="lista_padroes"]').html('');
                $('[modal_demos="lista_outros"]').html('');
            }
        }
    });
});
const ELS_test = document.querySelectorAll("#modal-demo-completo");
ELS_test.forEach(el => attrObserver.observe(el, {attributes: true}));



