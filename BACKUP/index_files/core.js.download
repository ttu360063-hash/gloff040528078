$(function() {
    $(document).on('click', '[tempo]:not(.disabled)', function(e){
        e.preventDefault(e);
        tempo = $(this).attr('tempo');
        frase = $(this).attr('mensagem') ? $(this).attr('mensagem') : 'Volto já';
        $.ajax({
            type: "POST",
            dataType: "json",
            url: DIR+"!/tempo",
            data: "tempo="+tempo+'&frase='+frase,
            success: function( data) {
