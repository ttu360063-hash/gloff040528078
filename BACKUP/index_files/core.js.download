$(document).on('click', '[excluirPedido]', function(){
    var action = $(this).attr('action');
    var ID = $(this).attr('excluirPedido');
    var reload = ($(this).attr('href') ? $(this).attr('href') : '');
    swal({
        title: "Tem certeza que deseja excluir este Pedido?",
        text: "Esta ação pode não ser desfeita.",
        type: "info",
        showCancelButton: true,
        showConfirmButton: true,
        confirmButtonText: 'Excluir',
        confirmButtonClass: 'swal2-confirm btn btn-danger m-btn m-btn--custom',
        cancelButtonText: 'Cancelar',
        closeOnConfirm: false,
        showLoaderOnConfirm: true,
    }, function(isConfirm){
        if (isConfirm) {     
            swal('Excluindo!', 'O pedido está sendo analisado para exclusão. Sua página será atualizada.', "success");
            $.ajax({
                type: "POST",
                dataType: "json",
                url: DIR+'!/solicitar',
                data: 'acao=excluir&pedido='+ID+'&reload='+reload,
                success: function( data ) {
                    retornoAjax(data);
                },
                error: function( data ) {
                    swal.close();
                    ajaxErro(data);
                }
            });
        }
    });
});

