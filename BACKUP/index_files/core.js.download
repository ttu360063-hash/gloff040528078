                        .removeClass('bg-gray-400 text-gray-600')
                        .addClass(data.cor)
                }
            },
            error: function( data ) {
                alert( 'Houve um erro imprevisto. Atualize a página.');
            }
        });
    });
    $(document).on('click', '[tempo_offline]', function(e){
        e.preventDefault(e);
        tempo = $(this).attr('tempo_usuario');
        usuario = $(this).attr('usuario');
        auto = $(this).attr('tempo_auto');
        if(auto == 1) {
            $('[ferias_parte1_self]').show();
            $('[ferias_parte1]').hide();
            $('[ferias_parte2]').hide();
        } else {
            $('[ferias_parte1]').show();
            $('[ferias_parte1_self]').hide();
            $('[ferias_parte2]').hide();
        }
        $('[modal-offline_usuario]').attr('usuario', usuario);
        $('#modal-offline_usuario').val(usuario);
        $('#modal-offline').modal('toggle');
    });
    $(document).on('click', '[tempo_ferias]', function(e){
        e.preventDefault(e);
        tempo = $(this).attr('tempo_usuario');
        usuario = $(this).attr('usuario');
        $('[ferias_parte1]').hide();
        $('[ferias_parte2]').show();
        $('#modal-offline_usuario').val(usuario);
        $('#modal-offline').modal('toggle');
    })
})







var Saida = function() {
    var vInformar = function(){
        jQuery('.js-adicionar-saida').each( function() {
            $($(this)).validate({
                errorClass: 'help-block text-right animated fadeInDown hidden',
                errorElement: 'div',
                errorPlacement: function(error, e) {
                    jQuery(e).parents('.form-group > div').append(error);
                },
                highlight: function(e) {
                    jQuery(e).closest('.form-group').removeClass('has-error').addClass('has-error');
                    jQuery(e).closest('.help-block').remove();
                },
                success: function(e) {
                    jQuery(e).closest('.form-group').addClass('has-error').removeClass('has-error');                
                    jQuery(e).closest('.help-block').remove();
                },
                rules: {
                    final: {
                        required: true,
                    },
                    mensagem: {
                        required: true,
                        minlength: 5
                    }
                },
                messages: {

                },
                submitHandler: function( form ){
                    console.log(form)
                    
                    var dados = $( form ).serialize();
                    var action = $( form ).attr('action');

                    $.ajax({
                        type: "POST",
                        dataType: "json",
                        url: action,
                        data: dados,
                        beforeSend: function() {
                            $('#block-adicionar-saida').addClass('block-opt-refresh');
                            $(this).find('input, textarea, button, select').attr('disabled', true);
                        },
                        success: function( data ) {
                            $('#block-adicionar-saida').removeClass('block-opt-refresh');
                            $(this).find('input, textarea, button, select').removeAttr('disabled');
                            retornoAjax(data);
                        },
                        error: function( data ) {
                            $('#block-adicionar-saida').removeClass('block-opt-refresh');
                            $(this).find('input, textarea, button, select').removeAttr('disabled');
                            ajaxErro(data)
                        }
                    });

                    return false;
                }
            });
        });
    };
    return {
        init: function () {
            vInformar()
        }
    };
}();
jQuery(function(){ Saida.init(); });


document.addEventListener('play', function(e){
    var audios = document.getElementsByTagName('audio');
    for(var i = 0, len = audios.length; i < len;i++){
        if(audios[i] != e.target){
            audios[i].pause();
        }
    }
}, true);

