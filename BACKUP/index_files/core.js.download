$('#formPesquisa').on("submit", function(e, inndex, newValue, oldValue) {
    e.preventDefault();
    pesquisa = $('#valor_pesquisa').val()
    action = $(this).attr('action');
    $.ajax({
        type: "POST",
        dataType: "json",
        url: action,
        data: 'pesquisa='+pesquisa,
        success: function( data ) {
            if (data.success) {
                window.location.href = data.href;
            } else {
                retornoAjax(data);
            }
        },
        error: function( data ) {
            console.log('Error: '+data.responseText);
            alert( 'Houve um erro imprevisto. Atualize a página.');
        }
    });
});


