/* Formulários */
var Formularios = function() {
    var ajax = function(){
        $('.ajax').each(function(e){

            var formulario = $(this);

            $(this).validate({
                rules: {
                    cpf: {
                        cpf: true,
                    },
                    cnpj: {
                        cnpj: true,
                    },
                },
                messages: {
                },
                submitHandler: function( form ){

                    dados = new FormData($(form).get(0));
                    reloadOnError = $(form).attr('reloadOnError');
                    $.ajax({
                        type: "POST",
                        dataType: "json",
                        url: $(form).attr('action'),
                        data: dados,
                        cache: false,
                        contentType: false,
                        processData: false,
                        timeout: 60000,
                        beforeSend: function() {
                            loader(form);
                        },
                        success: function( data ) {
                            unload(form);
                            retornoAjax(data);
                        },
                        error: function( data ) {
                            unload(form);
                            ajaxErro(data);
                            if(data.href == 'reload') {
                                setTimeout( function(){
                                    window.location.reload()
                                }, 1500)
                            } else if (data.href) {
                                setTimeout( function(){
                                    window.location.href = data.href
                                }, 1500)
                            }
                        },
                        completed: function (data) {
                            unload(form);
                        }
                    });
                    return false;
                }
            });
        });
    };

    var completed = function() {
        $(document).ajaxStop(function(){
            feather.replace();
        });
    }

    return {
        init: function () {
            // Init Login Form Validation
            ajax();
            completed();
        }
    };
}();
jQuery(document).ready(function() {
    Formularios.init();
    try {
        window.markAjaxScriptLoaded();
    } catch(error) {
        console.log(error);
    }
});

jQuery.validator.addMethod("cpf", function(value, element) {
  return validar(element, 'cpf-cnpj');
}, "Por favor, insira um CPF válido.");

jQuery.validator.addMethod("cnpj", function(value, element) {
  return validar(element, 'cpf-cnpj');
}, "Por favor, insira um CNPJ válido.");


