// ## Problema ## //
    // Abrir
    $(document).on('click', '[informar_problema]', function(e){

        var pedido = $(this).attr('pedido');
            $('#problema_pedido').val(pedido);
        $('[refazerPedido]').attr('href', $('[refazerPedido]').attr('o_href')+pedido);

        var produto = $(this).attr('produto');

        if (produto == 2) {
            $('[problema_produto2]').show();
        } else {
            $('[problema_produto2]').hide();
        }

        var action = $('#modal-problema').find('form').attr('action');

        $('#modal-problema').modal('toggle');

    })
    // Selecionar Problema
    $(document).on('click', '[problema_tipo]', function(e){
        tipo = $(this).attr('problema_tipo');
        $('#problema_tipo').val(tipo);
        
        $('[problema_tipo]').addClass('btn-simple');
        $(this).removeClass('btn-simple');

        $('[problema_parte2]').show('linear');
    })
    // Fechar, reseta CKeditor e Dropzone
    $("#modal-problema").on("hidden.bs.modal", function () {
        $('[problema_tipo]').addClass('btn-simple');
        $('[problema_parte2]').hide();
        $('#problema_pedido').val('');
        $('#problema_tipo').val('');
        ID = $('#modal-problema').find('[ckeditor]').attr('id');
        Dropzone.forElement("#modal-problema .dropzone").removeAllFiles(true);
    });

    // Resolver
    $(document).on('click', '[resolver_problema]', function(e){

        var problema = $(this).attr('problema');

        $.ajax({
            type: "POST",
            dataType: "json",
            url: DIR+'!/denunciar',
            data: 'acao=consulta&problema='+problema,
            beforeSend: function() {
                if (!$('#problema_resolver').val() != problema) {
                    ID = $('#modal-problema-resolver').find('[ckeditor]').attr('id')
                    Dropzone.forElement("#modal-problema-resolver .dropzone").removeAllFiles(true);
                }
            },
            success: function( data ) {
                if (data.success == true) {
                    $('#resolver_problema').val(data.ID);
                    $('#resolver_motivo').html(data.motivo);
                    $('#modal-problema-resolver').modal('toggle');

                    if (data.novo_locutor == 1) {
                        $('[resolver_locutor]').show();
                        $('[resolver_normal]').hide();
                    } else {
                        $('[resolver_locutor]').hide();
                        $('[resolver_normal]').show();
                    }
                }
                retornoAjax(data);
            },
            error: function( data ) {
                ajaxErro(data);
            }
        });
    })

    $(document).on('click', '[opcoes_resolver_locutor]', function(e){
        
        opcao = $(this).attr('opcoes_resolver_locutor');
        $('[opcoes_resolver_locutor]').addClass('btn-simple');
        $(this).removeClass('btn-simple');

        if (opcao == 'escolher') {

        } else if (opcao == 'cancelar') {
            confirmarSolucao();
        }
        
        $('[problema_tipo]').addClass('btn-simple');
        $(this).removeClass('btn-simple');

        $('[problema_parte2]').show('linear');
    })

