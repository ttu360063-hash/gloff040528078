$(document).on('click', '[resetarProdutor]', function(e){
    pedido = $(this).attr('pedido');
    action = DIR+'!/intervir';
    $.ajax({
        type: "POST",
        dataType: "json",
        url: action,
        data: 'acao=gerenciar&pedido='+pedido+'&reset-produtor=true',
        beforeSend: function() {
            $('#modal-gerenciar').waitMe({
                effect : 'orbit',
                text : 'Aguarde...',
                bg: 'rgba(255,255,255,0.7)',
                waitTime : -1,
                onClose : function() {}
            });
        },
        success: function( data ) {
            $('#modal-gerenciar').waitMe('hide');
            retornoAjax(data);
        },
        error: function( data ) {
            $('#modal-gerenciar').waitMe('hide');
            ajaxErro(data);
        },
        completed: function (data) {
            $('#modal-gerenciar').waitMe('hide');
        }
    });
})


// Abrir Edição Problema
$(document).on('click', '[solucao_admin]', function(e){
    acao = $(this).attr('solucao_admin');
    problema = $(this).attr('problema');
    if (acao == 'editar-problema') {
        $.ajax({
            type: "POST",
            dataType: "json",
            url: DIR+'!/denunciar',
            data: 'acao=get-problema&problema='+problema,
            success: function( data ) {
                $('#editar_problema_id').val(problema);
                $('#editar_problema_excluir').attr('problema', problema);
                $('#editar_problema_formulario').val(data.formulario);
                $('#modal-editar-problema').find('.dropzone').attr('formulario', data.formulario);
                $('#editar_problema_motivo').val(data.motivo);
                texto = $.parseHTML(data.motivo);
                texto = $(texto).text();
                $('#editar_problema_motivo').parent().find('[contenteditable="true"]').prepend(texto);
                ID = $('#modal-editar-problema').find('[ckeditor]').attr('id')
                $('#modal-editar-problema').modal('show');
            },
            error: function( data ) {
                ajaxErro();
            },
        });
    }
})

