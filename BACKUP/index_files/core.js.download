function notifyMe(mensagem) {
    webNotification.showNotification(SITE, {
        body: mensagem,
        icon: ICONE,
        onClick: function onNotificationClicked() {
            window.open(URL_DIR);
        },
        autoClose: 6000 //auto close the notification after 4 seconds (you can manually close it via hide function)
    }, function onShow(error, hide) {
        if (error) {
            console.log('Erro ao exibir notificação: ' + error.message);
        } else {
            setTimeout(function hideNotification() {
                hide();
            }, 7000);
        }
    });
}

