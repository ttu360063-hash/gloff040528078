var FormularioLocutor = function() {
    var ajaxLocutor = function(){
        $('.ajaxLocutor').each(function(e){

            var formulario = $(this);

            $(this).validate({
                submitHandler: function( form ){

                    dados = new FormData($(form).get(0));
                    /*
                    if (!dados.get('institucionais')) {
                        swal('Você grava textos Institucionais (Vídeos/TV) no Pacote?', 'Responda à pergunta acima para continuar!', "error");
                        return false;
                    } else if (!dados.get('religiosos')) {
                        swal('Você grava textos religiosos no pacote?', 'Responda à pergunta acima para continuar!', "error");
                        return false;
                    } else if (!dados.get('espera')) {
                        swal('Você grava espera telefônica no pacote?', 'Responda à pergunta acima para continuar!', "error");
                        return false;
                    } else {
                        */
                        $.ajax({
                            type: "POST",
                            dataType: "json",
                            url: $(form).attr('action'),
                            data: dados,
                            cache: false,
                            contentType: false,
                            processData: false,
                            beforeSend: function() {
                                loader(form);
                            },
                            success: function( data ) {
                                unload(form);
                                retornoAjax(data);
                            },
                            error: function( data ) {
                                unload(form);
                                ajaxErro(data);
                            },
                            completed: function (data) {
                                unload(form);
                            }
                        });
                    //}
                    //return false;
                }
            });
        });
    };

    return {
        init: function () {
            // Init Login Form Validation
            ajaxLocutor();
        }
    };
}();
jQuery(document).ready(function() { FormularioLocutor.init(); });



